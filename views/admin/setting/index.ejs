<!DOCTYPE html>
<html lang="en" data-theme="light">

<head>
    <%- include('../inc/style.ejs') %>
        <title>setting Page</title>
</head>

<body>
    <div class="flex ">
        <%- include('../inc/sidebar.ejs') %>
            <div class="flex-1">
                <%- include('../inc/header.ejs') %>

                    <div class="p-4">
                        <form action="/settings/update" method="post" enctype="multipart/form-data">

                            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">

                                <div class="mb-3 text-sm">
                                    <label class="block mb-1">Name (En)</label>
                                    <input type="text" name="nameEn" value="<%= setting.nameEn %>"  class="input input-primary w-full" />
                                </div>

                                <div class="mb-3 text-sm">
                                    <label class="block mb-1">Name (Ar)</label>
                                    <input type="text" name="nameAr" value="<%= setting.nameAr %>"  class="input input-primary w-full" />
                                </div>



                                <div class="mb-3 text-sm">
                                    <label class="block mb-1">Description (En)</label>
                                    <textarea type="text" name="descriptionEn"
                                        class="textarea textarea-primary w-full"> <%= setting.descriptionEn %> </textarea>
                                </div>

                                <div class="mb-3 text-sm">
                                    <label class="block mb-1">Description (Ar)</label>
                                    <textarea type="text" name="descriptionAr"
                                        class="textarea textarea-primary w-full"> <%= setting.descriptionAr %> </textarea>
                                </div>



                                <div class="mb-3 text-sm">
                                    <label class="block mb-1">Email</label>
                                    <input type="email" name="email" value="<%= setting.email %>" class="input input-primary w-full" />
                                </div>



                                <div class="mb-3 text-sm">
                                    <label class="block mb-1">Phone</label>
                                    <input type="text" name="phone" value="<%= setting.phone %>" class="input input-primary w-full" />
                                </div>



                                <div class="mb-3 text-sm">
                                    <label class="block mb-1">Address</label>
                                    <input type="text" name="address" value="<%= setting.address %>" class="input input-primary w-full" />
                                </div>


                                <div class="my-3">
                                    <div class="mb-5 flex justify-center items-center">
                                        <img class="w-44" src="/uploads/<%= setting.logo %>" alt="<%= setting.nameAr %>">
                                    </div>
                                   

                                    <label class="flex justify-center items-center flex-col py-4 text-sm border border-dashed " for="image">
                                       
                                        <div class="mb-2">
                                            <img src="" id="preview" alt="">
                                        </div>
                                         <input type="file" id="image" name="image"  class="file-input file-input-primary w-full hidden" />
                                        
                                        <div>
                                            <i class="fa-solid fa-file-image text-3xl"></i>
                                        </div>
                                    </label>
                                   
                                </div>



                                
                            </div>
                            <div>
                                <button class="btn btn-primary">update</button>
                            </div>
                        </form>
                    </div>
            </div>
    </div>
    <%- include('../inc/script.ejs') %>
</body>

</html>